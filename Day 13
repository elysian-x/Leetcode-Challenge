class Solution {
    public int countEven(int num) {
        int flag = 0;
        for(int i=1;i<=num;i++){
            int sum =i;
            int temp=i;
            if (i>0){
                sum=0;
            while(temp>0){
                sum=sum+temp%10;
                temp/=10;
            }
            }
            if(sum%2==0){
                flag++;
            }
        }
        return flag;
    }
}
                
